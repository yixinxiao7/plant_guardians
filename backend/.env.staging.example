# backend/.env.staging.example
# Template for the staging environment secrets file.
# On the staging server, copy this to backend/.env.staging and populate all values.
# The actual .env.staging is listed in .gitignore and must NEVER be committed.

NODE_ENV=staging
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_64_BYTE_HEX
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# The public URL of the frontend on staging
FRONTEND_URL=https://staging.plant-guardians.example.com

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=5

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20
