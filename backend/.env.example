# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection URL
DATABASE_URL=postgresql://plant_guardians:plant_guardians_dev@localhost:5432/plant_guardians_dev

# Test database (used when NODE_ENV=test — runs against a separate DB to keep dev data safe)
TEST_DATABASE_URL=postgresql://plant_guardians:plant_guardians_dev@localhost:5433/plant_guardians_test

# ─── Authentication ───────────────────────────────────────────────────────────
# Long, random secret — generate with: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# :5173 = Vite dev server (primary), :5174 = Vite dev server (secondary/alternate)
# :4173 = Vite preview (canonical fixed port — package.json preview script uses --port 4173)
# :4175 = Vite preview (fallback — in case prior preview processes occupy 4173/4174)
# Keep both :4173 and :4175 here so staging CORS never breaks due to port drift.
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:4173,http://localhost:4175

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Obtain from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# ─── Email / Notifications (T-101) ────────────────────────────────────────────
# All optional — backend starts cleanly without these; email sending is disabled.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Plant Guardians <noreply@plantguardians.app>
UNSUBSCRIBE_SECRET=your-unsubscribe-hmac-secret
APP_BASE_URL=http://localhost:5173

# ─── Google OAuth (T-120) ─────────────────────────────────────────────────────
# Both optional — backend starts cleanly without these; Google OAuth is disabled.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Rate Limiting (T-111) ────────────────────────────────────────────────────
# Auth endpoints (POST /auth/login, /register, /refresh) — strictest tier
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000

# Stats/streak endpoints (GET /care-actions/stats, /streak) — moderate tier
RATE_LIMIT_STATS_MAX=60
RATE_LIMIT_STATS_WINDOW_MS=60000

# Global fallback (all other /api/v1/* routes) — most permissive tier
RATE_LIMIT_GLOBAL_MAX=200
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
