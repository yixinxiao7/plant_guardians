# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection URL
DATABASE_URL=postgresql://plant_guardians:plant_guardians_dev@localhost:5432/plant_guardians_dev

# Test database (used when NODE_ENV=test — runs against a separate DB to keep dev data safe)
TEST_DATABASE_URL=postgresql://plant_guardians:plant_guardians_dev@localhost:5433/plant_guardians_test

# ─── Authentication ───────────────────────────────────────────────────────────
# Long, random secret — generate with: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# :5173 = Vite dev server, :5174 = Vite dev server (secondary/alternate port), :4173 = Vite preview
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:4173

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Obtain from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# General API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth-specific rate limit (stricter — prevents brute force on login/register)
AUTH_RATE_LIMIT_MAX=20
