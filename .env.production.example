# .env.production.example — Production environment variable template
#
# USAGE:
#   cp .env.production.example .env.production
#   # Fill in ALL values marked REPLACE_ME
#   # This file is committed to git as a template.
#   # .env.production is listed in .gitignore and must NEVER be committed.
#
# IMPORTANT: Never store secrets in this file. Only placeholders and documentation.

# ─── Docker Compose / Stack ────────────────────────────────────────────────────

# PostgreSQL credentials
# Use a strong, randomly generated password:  openssl rand -hex 32
POSTGRES_USER=plant_guardians
POSTGRES_PASSWORD=REPLACE_ME_strong_db_password
POSTGRES_DB=plant_guardians_prod

# ─── Backend (Express API) ─────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# JWT signing secret — generate with: openssl rand -hex 64
# Must be different from staging. Rotate every 90 days.
JWT_SECRET=REPLACE_ME_64_byte_hex_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Google Gemini API key — obtain from https://makersuite.google.com/app/apikey
# Required for AI plant advice feature. Without this key, POST /ai/advice returns
# 502 AI_SERVICE_UNAVAILABLE (gracefully handled by the frontend).
GEMINI_API_KEY=REPLACE_ME_gemini_api_key

# Maximum plant photo upload size in megabytes
MAX_UPLOAD_SIZE_MB=5

# Rate limiting — adjust based on expected production traffic
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ─── CORS ──────────────────────────────────────────────────────────────────────
# The public HTTPS URL of your production frontend.
# This must match the domain served by nginx (including scheme, no trailing slash).
# Example: https://plantguardians.app
FRONTEND_URL=https://REPLACE_ME_your_domain.com

# ─── SSL Certificates (for nginx HTTPS termination) ───────────────────────────
# Absolute paths on the HOST machine to your SSL certificate files.
#
# Option A — Let's Encrypt (recommended for production):
#   1. Install certbot: https://certbot.eff.org/
#   2. Obtain cert:  certbot certonly --standalone -d yourdomain.com
#   3. Set paths below:
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
#
# Option B — Bring-your-own CA cert:
#   1. Place fullchain.pem and privkey.pem in infra/ssl/ (directory is gitignored)
#   2. Set paths below:
# SSL_CERT_PATH=/opt/plant-guardians/infra/ssl/fullchain.pem
# SSL_KEY_PATH=/opt/plant-guardians/infra/ssl/privkey.pem

SSL_CERT_PATH=REPLACE_ME_/path/to/fullchain.pem
SSL_KEY_PATH=REPLACE_ME_/path/to/privkey.pem

# ─── Frontend Build (Vite) ─────────────────────────────────────────────────────
# Leave empty in production — nginx proxies /api/* to the backend container
# so the compiled React app uses relative paths and no CORS issues arise.
# Only set this if deploying the frontend to a completely separate domain from
# the backend (unusual — not recommended for this architecture).
VITE_API_BASE_URL=
