# ─── API Base URL ─────────────────────────────────────────────────────────────
# In local development and staging this variable is NOT required.
# The Vite dev server (npm run dev) and preview server (npm run preview) proxy
# all /api/* requests to http://localhost:3000 via the proxy config in
# vite.config.js, so the app talks to the backend without CORS issues.
#
# Set this variable ONLY when deploying to a production environment where the
# backend is hosted at a different origin from the frontend, e.g.:
#   VITE_API_BASE_URL=https://api.plantguardians.app/api/v1
#
# Leave unset (or leave this file as-is) for local dev and staging.
# VITE_API_BASE_URL=https://api.plantguardians.app/api/v1
